{
  "name": "proxyparser",
  "version": "1.0.0",
  "private": true,
  "description": "Bun monorepo for proxy subscription parsing, rule patching, and a small operations dashboard.",
  "author": "Paperside",
  "license": "ISC",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --workspaces --parallel dev",
    "start": "bun run --workspaces --parallel start",
    "build": "bun run --workspaces build",
    "typecheck": "bun run --workspaces typecheck",
    "dev:backend": "bun run --filter @proxyparser/backend dev",
    "dev:frontend": "bun run --filter @proxyparser/frontend dev",
    "start:backend": "bun run --filter @proxyparser/backend start",
    "start:frontend": "bun run --filter @proxyparser/frontend start"
  }
}
