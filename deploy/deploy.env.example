# Copy this file to deploy/deploy.env before running scripts/deploy-images.sh.
# deploy/deploy.env is ignored by git and may contain machine-specific targets.

# Required unless --target is passed to scripts/deploy-images.sh.
PROXYPARSER_DEPLOY_TARGET=deploy@example.com

# Optional. Defaults to /opt/proxyparser.
PROXYPARSER_REMOTE_ROOT=/opt/proxyparser

# Optional. Defaults to dist/images under the repository root.
# OUTPUT_DIR=/absolute/path/to/image-archives
